---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function timeAgo(date: Date) {
  const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
  const days = Math.floor(seconds / 86400);
  const weeks = Math.floor(days / 7);
  const months = Math.floor(days / 30);
  if (months > 0) return `${months} month${months > 1 ? 's' : ''} ago`;
  if (weeks > 0) return `${weeks} week${weeks > 1 ? 's' : ''} ago`;
  if (days > 0) return `${days}d ago`;
  return 'Today';
}
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        background-color: #0f1f3d;
      }
      .page-wrapper {
        max-width: 680px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
      }
      .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        color: white;
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .post-list {
        display: flex;
        flex-direction: column;
      }
      .post-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        text-decoration: none;
        transition: background 0.2s;
      }
      .post-item:hover {
        opacity: 0.8;
      }
      .post-icon {
        width: 44px;
        height: 44px;
        min-width: 44px;
        border-radius: 50%;
        background-color: #1a3260;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b9fff;
        font-weight: 700;
        font-size: 1rem;
      }
      .post-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .post-title {
        font-family: 'Source Serif 4', serif;
        font-size: 1rem;
        color: white;
        line-height: 1.4;
      }
      .post-meta {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
      }
      .empty-state {
        text-align: center;
        color: rgba(255,255,255,0.4);
        font-style: italic;
        padding: 3rem 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-wrapper">
        <h1 class="page-title">Student Commodity Insights</h1>
        <div class="post-list">
          {posts.length === 0 && (
            <p class="empty-state">No posts yet — check back soon.</p>
          )}
          {posts.map((post) => (
            <a class="post-item" href={`/blog/${post.slug}/`}>
              <div class="post-icon">S</div>
              <div class="post-info">
                <span class="post-title">{post.data.title}</span>
                <span class="post-meta">{timeAgo(new Date(post.data.pubDate))} · Student Commodity Insights</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
