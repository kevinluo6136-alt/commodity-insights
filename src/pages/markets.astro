---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Markets | Student Commodity Insights" description="Live oil futures prices" />
    <style>
      .page-wrapper {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .page-header {
        border-bottom: 2px solid var(--navy);
        padding-bottom: 1.5rem;
        margin-bottom: 2.5rem;
      }
      .page-header h1 { font-size: 2rem; color: var(--navy); }
      .page-header p { color: var(--text-muted); font-size: 0.9rem; margin-top: 0.3rem; }
      .chart-section {
        margin-bottom: 2.5rem;
        border-radius: 12px;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-wrapper">
        <div class="page-header">
          <h1>Oil Futures</h1>
          <p>Live WTI & Brent crude oil prices</p>
        </div>

        <div class="chart-section">
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-single-quote.js" async>
            {
              "symbol": "TVC:USOIL",
              "width": "100%",
              "colorTheme": "dark",
              "isTransparent": false,
              "locale": "en"
            }
            </script>
          </div>
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
            {
              "symbol": "TVC:USOIL",
              "width": "100%",
              "height": "400",
              "locale": "en",
              "dateRange": "5D",
              "colorTheme": "dark",
              "trendLineColor": "rgba(74, 222, 128, 1)",
              "underLineColor": "rgba(74, 222, 128, 0.1)",
              "isTransparent": false,
              "autosize": true
            }
            </script>
          </div>
        </div>

        <div class="chart-section">
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-single-quote.js" async>
            {
              "symbol": "TVC:UKOIL",
              "width": "100%",
              "colorTheme": "dark",
              "isTransparent": false,
              "locale": "en"
            }
            </script>
          </div>
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
            {
              "symbol": "TVC:UKOIL",
              "width": "100%",
              "height": "400",
              "locale": "en",
              "dateRange": "5D",
              "colorTheme": "dark",
              "trendLineColor": "rgba(74, 222, 128, 1)",
              "underLineColor": "rgba(74, 222, 128, 0.1)",
              "isTransparent": false,
              "autosize": true
            }
            </script>
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>
