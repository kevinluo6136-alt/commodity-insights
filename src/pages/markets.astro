---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Markets | Student Commodity Insights" description="Live oil futures prices" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
      .page-wrapper {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .page-header {
        border-bottom: 2px solid var(--navy);
        padding-bottom: 1.5rem;
        margin-bottom: 2.5rem;
      }
      .page-header h1 {
        font-size: 2rem;
        color: var(--navy);
      }
      .page-header p {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-top: 0.3rem;
      }
      .prices-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
      }
      .price-card {
        background: var(--navy);
        border-radius: 12px;
        padding: 1.8rem;
        color: white;
      }
      .price-card .label {
        font-size: 0.85rem;
        opacity: 0.6;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
      }
      .price-card .price {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
      }
      .price-card .change {
        font-size: 0.95rem;
        font-weight: 600;
      }
      .change.up { color: #4ade80; }
      .change.down { color: #f87171; }
      .loading { opacity: 0.5; font-style: italic; }
      .chart-section {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      }
      .chart-section h2 {
        font-size: 1.1rem;
        color: var(--navy);
        margin-bottom: 1rem;
      }
      .chart-wrapper {
        position: relative;
        height: 200px;
      }
      .last-updated {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-align: right;
        margin-top: 1rem;
      }
      @media (max-width: 500px) {
        .prices-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-wrapper">
        <div class="page-header">
          <h1>Oil Futures</h1>
          <p>Live WTI & Brent crude oil prices — updates every 30 seconds</p>
        </div>

        <div class="prices-grid">
          <div class="price-card">
            <div class="label">WTI Crude Oil</div>
            <div class="price loading" id="wti-price">Loading...</div>
            <div class="change" id="wti-change"></div>
          </div>
          <div class="price-card">
            <div class="label">Brent Crude Oil</div>
            <div class="price loading" id="brent-price">Loading...</div>
            <div class="change" id="brent-change"></div>
          </div>
        </div>

        <div class="chart-section">
          <h2>WTI Crude — Today's Price Movement</h2>
          <div class="chart-wrapper">
            <canvas id="wti-chart"></canvas>
          </div>
        </div>

        <div class="chart-section">
          <h2>Brent Crude — Today's Price Movement</h2>
          <div class="chart-wrapper">
            <canvas id="brent-chart"></canvas>
          </div>
        </div>

        <p class="last-updated" id="last-updated"></p>
      </div>
    </main>
    <Footer />

    <script>
      let wtiChart: any = null;
      let brentChart: any = null;

      function formatTime(timestamp: number) {
        const d = new Date(timestamp * 1000);
        return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
      }

      function buildChart(canvasId: string, labels: string[], prices: number[], color: string, existingChart: any) {
        if (existingChart) existingChart.destroy();
        const ctx = (document.getElementById(canvasId) as HTMLCanvasElement).getContext('2d')!;
        return new (window as any).Chart(ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [{
              data: prices,
              borderColor: color,
              backgroundColor: color + '18',
              borderWidth: 2,
              pointRadius: 0,
              fill: true,
              tension: 0.3
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: {
                ticks: { maxTicksLimit: 6, font: { size: 11 } },
                grid: { display: false }
              },
              y: {
                ticks: {
                  font: { size: 11 },
                  callback: (v: number) => `$${v.toFixed(2)}`
                },
                grid: { color: 'rgba(0,0,0,0.05)' }
              }
            }
          }
        });
      }

      async function fetchData(symbol: string) {
const res = await fetch(`https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1h&range=5d`);
        const data = await res.json();
        const result = data.chart.result[0];
        const meta = result.meta;
        const timestamps = result.timestamp || [];
        const closes = result.indicators.quote[0].close || [];

        const labels = timestamps.map((t: number) => formatTime(t));
        const prices = closes.map((p: number | null) => p ?? null);

        return {
          price: meta.regularMarketPrice.toFixed(2),
          change: (meta.regularMarketPrice - meta.chartPreviousClose).toFixed(2),
          pct: (((meta.regularMarketPrice - meta.chartPreviousClose) / meta.chartPreviousClose) * 100).toFixed(2),
          labels,
          prices
        };
      }

      function updateCard(idPrice: string, idChange: string, data: any) {
        const priceEl = document.getElementById(idPrice)!;
        const changeEl = document.getElementById(idChange)!;
        priceEl.textContent = `$${data.price}`;
        priceEl.classList.remove('loading');
        const up = Number(data.change) >= 0;
        changeEl.textContent = `${up ? '▲' : '▼'} $${Math.abs(Number(data.change))} (${data.pct}%)`;
        changeEl.className = `change ${up ? 'up' : 'down'}`;
      }

      async function loadAll() {
        try {
          const [wti, brent] = await Promise.all([
            fetchData('CL=F'),
            fetchData('BZ=F')
          ]);

          updateCard('wti-price', 'wti-change', wti);
          updateCard('brent-price', 'brent-change', brent);

          const wtiColor = Number(wti.change) >= 0 ? '#4ade80' : '#f87171';
          const brentColor = Number(brent.change) >= 0 ? '#4ade80' : '#f87171';

          wtiChart = buildChart('wti-chart', wti.labels, wti.prices, wtiColor, wtiChart);
          brentChart = buildChart('brent-chart', brent.labels, brent.prices, brentColor, brentChart);

          document.getElementById('last-updated')!.textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
        } catch (e) {
          document.getElementById('wti-price')!.textContent = 'Unavailable';
          document.getElementById('brent-price')!.textContent = 'Unavailable';
        }
      }

      loadAll();
      setInterval(loadAll, 30000);
    </script>
  </body>
</html>
