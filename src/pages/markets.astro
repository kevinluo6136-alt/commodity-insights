---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Markets | Student Commodity Insights" description="Live oil futures prices" />
    <style>
      .page-wrapper {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .page-header {
        border-bottom: 2px solid var(--navy);
        padding-bottom: 1.5rem;
        margin-bottom: 2.5rem;
      }
      .page-header h1 { font-size: 2rem; color: var(--navy); }
      .page-header p { color: var(--text-muted); font-size: 0.9rem; margin-top: 0.3rem; }
      .chart-section {
        margin-bottom: 2.5rem;
        border-radius: 12px;
        overflow: hidden;
      }
      .chart-section h2 {
        font-size: 1.1rem;
        color: var(--navy);
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-wrapper">
        <div class="page-header">
          <h1>Oil Futures</h1>
          <p>Live WTI & Brent crude oil prices</p>
        </div>

        <div class="chart-section">
          <h2>WTI Crude Oil (CL1!)</h2>
          <div class="tradingview-widget-container">
            <div id="wti-widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js" async>
            {
              "symbol": "NYMEX:CL1!",
              "interval": "60",
              "range": "5D",
              "width": "100%",
              "height": "400",
              "theme": "dark",
              "style": "1",
              "locale": "en",
              "toolbar_bg": "#0f1f3d",
              "enable_publishing": false,
              "hide_top_toolbar": false,
              "hide_legend": false,
              "save_image": false,
              "container_id": "wti-widget"
            }
            </script>
          </div>
        </div>

        <div class="chart-section">
          <h2>Brent Crude Oil (BZ1!)</h2>
          <div class="tradingview-widget-container">
            <div id="brent-widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js" async>
            {
              "symbol": "ICEUS:B1!",
              "interval": "60",
              "range": "5D",
              "width": "100%",
              "height": "400",
              "theme": "dark",
              "style": "1",
              "locale": "en",
              "toolbar_bg": "#0f1f3d",
              "enable_publishing": false,
              "hide_top_toolbar": false,
              "hide_legend": false,
              "save_image": false,
              "container_id": "brent-widget"
            }
            </script>
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>
